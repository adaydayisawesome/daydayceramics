# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# sandbox: separate git dir workaround (.git/hooks is blocked here)
/.gitdir/

# typescript
*.tsbuildinfo
next-env.d.ts

# spin-pipeline: intermediate working dir + redundant per-frame exports.
# The runtime sprite sheet (sprite.webp) + manifest.json ARE committed so the
# spin deploys; the individual frames/ are only an intermediate output (the
# player reads the sprite) and are kept out of git.
.spin-tmp/
/public/images/spin/*/frames/

# asset-pipeline: raw photo/video drop zone (local-only intake). Processed,
# optimized web assets are written into /public/images and ARE committed; the
# heavy originals here never are. See tools/asset-pipeline/README.md.
/assets-incoming/
